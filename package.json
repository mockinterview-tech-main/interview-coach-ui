{
	"name": "sveltekit-pocketbase-starter",
	"version": "0.0.1",
	"author": "Dominick Caponi <d.caponi1@gmail.com>",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "npm run prepare",
		"prepare": "npm run smui-theme-light && npm run smui-theme-dark",
		"smui-theme-light": "smui-theme compile static/smui.css -i src/theme",
		"smui-theme-dark": "smui-theme compile static/smui-dark.css -i src/theme/dark",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@smui-extra/accordion": "^7.0.0-beta.16",
		"@smui/button": "^7.0.0-beta.16",
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/adapter-static": "^1.0.0-next.50",
		"@sveltejs/adapter-vercel": "^1.0.0-next.88",
		"@sveltejs/kit": "^1.20.4",
		"@types/stripe-v3": "^3.1.29",
		"audio-recorder-polyfill": "^0.4.1",
		"smui-theme": "^7.0.0-beta.16",
		"svelte": "^4.0.0",
		"svelte-check": "^3.4.3",
		"svelte-preprocess": "^5.0.4",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^4.3.6",
		"vitest": "^0.34.3"
	},
	"type": "module",
	"dependencies": {
		"@breezystack/lamejs": "^1.2.7",
		"@fontsource/inter": "^5.0.8",
		"@material-ui/core": "^4.12.4",
		"@material/dom": "^14.0.0",
		"@stripe/stripe-js": "^2.1.6",
		"@types/jsonwebtoken": "^9.0.3",
		"jsonwebtoken": "^9.0.2",
		"openai": "^4.16.1",
		"pocketbase": "^0.15.2",
		"sass": "^1.67.0",
		"stripe": "^13.7.0"
	}
}
